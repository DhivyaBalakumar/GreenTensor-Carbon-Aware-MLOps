   "cell_type": "code",
   "metadata": {},
   "source": [
    "from greentensor import DigitalFootprintScanner, DigitalFootprintEvent, FootprintReport\n",
    "import tempfile, os\n",
    "\n",
    "pre_events = []\n",
    "\n",
    "def footprint_handler(event: DigitalFootprintEvent):\n",
    "    pre_events.append(event)\n",
    "    print(f\"  [FOOTPRINT/{event.severity.upper()}] [{event.category}] [MITRE:{event.mitre_technique}]\")\n",
    "    print(f\"    {event.message[:100]}\")\n",
    "\n",
    "# Pre-deployment scanner\n",
    "scanner = DigitalFootprintScanner(\n",
    "    stage=\"pre_deployment\",\n",
    "    on_event=footprint_handler,\n",
    "    monitor_network=True,\n",
    "    monitor_processes=True,\n",
    ")\n",
    "\n",
    "with scanner:\n",
    "    # 1. Register model file before training\n",
    "    with tempfile.NamedTemporaryFile(suffix=\".pt\", delete=False) as f:\n",
    "        model_path = f.name\n",
    "        torch.save(make_model().state_dict(), f)\n",
    "\n",
    "    scanner.register_model_file(model_path)\n",
    "    print(f\"Model registered: {os.path.basename(model_path)}\")\n",
    "\n",
    "    # 2. Train\n",
    "    model = make_model()\n",
    "    train_loop(model, n_iters=5)\n",
    "\n",
    "    # 3. Verify model file hasn't been tampered with\n",
    "    tamper_events = scanner.verify_model_files()\n",
    "    if not tamper_events:\n",
    "        print(\"Model integrity check: PASSED (hash unchanged)\")\n",
    "\n",
    "    # 4. Scan dependencies for supply chain attacks\n",
    "    dep_events = scanner.scan_dependencies()\n",
    "    if not dep_events:\n",
    "        print(\"Dependency scan: CLEAN (no typosquatting or malicious packages)\")\n",
    "\n",
    "    # 5. Check a trusted network connection\n",
    "    is_trusted = scanner.check_network_connection(\"huggingface.co\", 443)\n",
    "    print(f\"huggingface.co trusted: {is_trusted}\")\n",
    "\n",
    "    # 6. Check an untrusted connection (triggers alert)\n",
