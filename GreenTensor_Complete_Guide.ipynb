    "print(\"Savings Summary\")\n",
    "print(\"-\" * 40)\n",
    "print(f\"  Energy saved     : {savings['energy_saved_kwh']:.6f} kWh\")\n",
    "print(f\"  CO2 saved        : {savings['emissions_saved_kg']:.6f} kg\")\n",
    "print(f\"  Energy reduction : {savings['energy_reduction_pct']:.1f}%\")\n",
    "print(f\"  Time saved       : {savings['time_saved_s']:.3f} s\")\n",
    "\n",
    "# Simulate realistic savings for a production model (scale up)\n",
    "scale = 1000  # 1000 training runs per year\n",
    "annual_energy_saved = savings['energy_saved_kwh'] * scale\n",
    "annual_co2_saved = savings['emissions_saved_kg'] * scale\n",
    "print(f\"\\nProjected annual savings (x{scale} runs):\")\n",
    "print(f\"  Energy : {annual_energy_saved:.4f} kWh\")\n",
    "print(f\"  CO2    : {annual_co2_saved:.4f} kg  (~{annual_co2_saved/0.192:.1f} km of driving avoided)\")"
   ],
   "execution_count": null,
   "outputs": []
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Feature 3: Batch Size Optimizer\n",
    "\n",
    "`optimize_batch_size()` queries available GPU memory and recommends the optimal batch size.\n",
    "\n",
    "**Why it matters:** Small batches cause high kernel launch overhead relative to compute. On a GPU with 8GB free memory, a batch of 32 might be 4x underutilizing the hardware. The optimizer scales the batch proportionally to free memory, capped by `Config.max_batch_size`.\n",
    "\n",
    "On CPU (no GPU), it doubles the batch if below the minimum threshold.\n"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "from greentensor import optimize_batch_size, Config\n",
    "\n",
    "# Default config\n",
    "for current_batch in [8, 16, 32, 64, 128]:\n",
    "    recommended = optimize_batch_size(current_batch)\n",
    "    change = \"(no change)\" if recommended == current_batch else f\"-> {recommended}\"\n",
    "    print(f\"  Current batch: {current_batch:4d}  |  Recommended: {recommended:4d}  {change}\")\n",
    "\n",
    "print()\n",
    "\n",
    "# Custom config â€” cap at 256\n",
    "cfg = Config()\n",
    "cfg.max_batch_size = 256\n",
    "cfg.min_batch_size = 32\n",
    "recommended = optimize_batch_size(16, config=cfg)\n",
    "print(f\"Custom config (max=256, min=32): batch 16 -> {recommended}\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Use the recommended batch size in a real training run\n",
    "from greentensor import GreenTensor\n",
    "\n",
    "optimal_batch = optimize_batch_size(32)\n",
    "print(f\"Using optimal batch size: {optimal_batch}\")\n",
    "\n",
    "model = make_model()\n",
    "with GreenTensor(verbose=False) as gt:\n",
    "    train_loop(model, n_iters=8, batch_size=optimal_batch)\n",
    "\n",
    "print(f\"Training complete: {gt.metrics.energy_kwh:.6f} kWh | {gt.metrics.duration_s:.3f}s\")"
   ],
   "execution_count": null,
   "outputs": []
  },

