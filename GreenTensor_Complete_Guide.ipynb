    "    print(f\"198.51.100.42:4444 trusted: {is_trusted_unknown}\")\n",
    "\n",
    "report = scanner.report\n",
    "print(f\"\\nPre-deployment report: {len(report.events)} events | clean={report.is_clean}\")\n",
    "os.unlink(model_path)"
   ],
